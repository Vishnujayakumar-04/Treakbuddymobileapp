# TrekBuddy Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git!

# Firebase (required for auth, Firestore, storage)
EXPO_PUBLIC_FIREBASE_API_KEY="your-firebase-api-key-here"

# Groq AI API (required for AI Chatbot and Trip Planner)
EXPO_PUBLIC_GROQ_API_KEY="your-groq-api-key-here"

# How to get these keys:
# Firebase: https://console.firebase.google.com -> Project Settings -> Your Apps
# Groq:     https://console.groq.com -> API Keys
